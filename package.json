{
  "name": "mcp-easyar",
  "version": "0.1.0",
  "description": "Official EasyAR MCP server for registered users building EasyAR Unity samples and projects.",
  "type": "module",
  "bin": {
    "easyar-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "assets/easyar-icon.png",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "pack:check": "npm run build && npm pack --dry-run",
    "start": "node dist/index.js",
    "test": "npm run build && node scripts/smoke-test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "easyar",
    "mcp",
    "unity",
    "augmented-reality"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/terri1982/mcp-easyar.git"
  },
  "bugs": {
    "url": "https://github.com/terri1982/mcp-easyar/issues"
  },
  "homepage": "https://github.com/terri1982/mcp-easyar#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
