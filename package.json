{
  "name": "mcp-easyar",
  "version": "0.1.0",
  "description": "Official EasyAR MCP server for registered users building EasyAR Unity samples and projects.",
  "type": "module",
  "bin": {
    "easyar-mcp": "dist/index.js",
    "easyar-mcp-check": "dist/install-check.js"
  },
  "files": [
    "dist",
    "docs/OFFICIAL_API_CONTRACT.md",
    "docs/OFFICIAL_API_HANDOFF.md",
    "docs/quickstart.md",
    "docs/RELEASE_MANIFEST.md",
    "docs/troubleshooting.md",
    "assets/easyar-icon.png",
    ".env.example",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "bin:smoke": "npm run build && MCP_EASYAR_SMOKE_COMMAND=./dist/index.js node scripts/smoke-test.mjs",
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "install:check": "npm run build && node dist/install-check.js",
    "package:smoke": "npm run build && node scripts/package-install-smoke.mjs",
    "pack:check": "npm run build && npm pack --dry-run",
    "postbuild": "chmod +x dist/index.js dist/install-check.js",
    "release:check": "node scripts/release-check.mjs",
    "security:check": "node scripts/security-check.mjs",
    "start": "node dist/index.js",
    "test": "npm run build && node scripts/smoke-test.mjs && node scripts/official-api-fixture-smoke.mjs",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "easyar",
    "mcp",
    "unity",
    "augmented-reality"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/terri1982/mcp-easyar.git"
  },
  "bugs": {
    "url": "https://github.com/terri1982/mcp-easyar/issues"
  },
  "homepage": "https://github.com/terri1982/mcp-easyar#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
