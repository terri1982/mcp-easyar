# mcp-easyar environment example.
# Copy to a local secret store or MCP client env config. Do not commit real values.

# Official EasyAR account API endpoints.
EASYAR_API_BASE_URL=https://www.easyar.cn
EASYAR_API_TOKEN=your_registered_user_token
EASYAR_ACCOUNT_STATUS_ENDPOINT=https://www.easyar.cn/path/to/official/account/status
EASYAR_LICENSE_VALIDATE_ENDPOINT=https://www.easyar.cn/path/to/official/license/validate
EASYAR_DOWNLOADS_ENDPOINT=https://www.easyar.cn/path/to/official/downloads
EASYAR_CLOUD_CREDENTIALS_ENDPOINT=https://www.easyar.cn/path/to/official/cloud-recognition/credentials

# Unity batch automation.
EASYAR_UNITY_PATH=/Applications/Unity/Hub/Editor/2022.3.62f1/Unity.app/Contents/MacOS/Unity
EASYAR_UNITY_CANDIDATE_DIRS=/Applications/Unity/Hub/Editor

# Optional local Unity project config values consumed by easyar_write_local_config_from_env.
EASYAR_LICENSE_KEY=your_easyar_sense_license_key
EASYAR_BUNDLE_IDENTIFIER=com.company.easyarsample
EASYAR_CLOUD_APP_ID=your_cloud_recognition_app_id
EASYAR_CLOUD_API_KEY=your_cloud_recognition_api_key
EASYAR_CLOUD_API_SECRET=your_cloud_recognition_api_secret_if_available
# Legacy aliases are still accepted by easyar_write_local_config_from_env:
# EASYAR_CLOUD_APP_KEY=your_cloud_recognition_api_key
# EASYAR_CLOUD_APP_SECRET=your_cloud_recognition_api_secret
